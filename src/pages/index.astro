---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div class="boxes">
		<div class="box"></div>
		<div class="box"></div>
	</div>
</Layout>

<style>
	.boxes {
		display: flex;
		flex-direction: column;
		gap: 96px;
		box-sizing: border-box;
	}

	.box {
		width: 100%;
		height: 100vh;
		background-color: rgb(245, 245, 245);
	}
</style>
