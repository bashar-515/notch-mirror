---
import type { Link as BaseLink } from "../types";

type Link = BaseLink & { isTitle?: boolean };

const linkClass = "font-sans";

const links: Link[] = [
  { href: "/issues", label: "ISSUES" },
  { href: "/events", label: "EVENTS" },
  { href: "/", label: "NOTCH MAGAZINE", isTitle: true },
  { href: "/stockists", label: "STOCKISTS" },
  { href: "/shop", label: "SHOP" },
];
---

<nav
  class="bg-secondary text-primary flex items-center justify-between border border-4 border-green-500"
>
  <div class="flex w-full items-center justify-between px-18">
    {
      links.map((link) => (
        <a
          href={link.href}
          class={
            link.isTitle
              ? `${linkClass} text-6xl`
              : `${linkClass} text-3xl ${Astro.url.pathname === link.href ? "" : "hover:underline"}`
          }
        >
          {link.label}
        </a>
      ))
    }
  </div>
</nav>
