---
import type { Link } from "../types";

const links: Link[] = [
  { href: "/issues", label: "ISSUES" },
  { href: "/events", label: "EVENTS" },
  { href: "/", label: "NOTCH MAGAZINE" },
  { href: "/stockists", label: "STOCKISTS" },
  { href: "/shop", label: "SHOP" },
];
---

<nav
  class="bg-secondary text-primary sticky top-0 flex items-center justify-between px-27 py-3"
>
  {
    links.map((link) => (
      <a
        href={link.href}
        class={
          link.href === "/"
            ? "font-sans text-6xl"
            : `font-sans text-3xl ${Astro.url.pathname === link.href ? "" : "hover:underline"}`
        }
      >
        {link.label}
      </a>
    ))
  }
</nav>
