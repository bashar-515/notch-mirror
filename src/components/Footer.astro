---
import Logo from "../components/icons/Logo.astro";
import type { Link } from "../types";

const linksByColumn: Link[][] = [
  [
    { href: "/about", label: "About" },
    { href: "/events", label: "Events" },
  ],
  [
    { href: "/issues", label: "Issues" },
    { href: "/stockists", label: "Stockists" },
  ],
  [
    { href: "/donate", label: "Support" },
    { href: "/shop", label: "Subscribe" },
  ],
  [
    { href: "/shop", label: "Shop" },
    { href: "/submissions", label: "Submissions" },
  ],
];
---

<footer class="bg-tertiary w-full">
  <div class="flex justify-between">
    <div>
      <a href="/" class="hover:text-secondary text-white">
        <Logo class="h-16 w-auto" />
      </a>
    </div>

    <div class="text-primary flex gap-4 self-center">
      {
        linksByColumn.map((column) => (
          <div class="flex flex-col">
            {column.map((link) => (
              <a href={link.href} class="hover:text-secondary">
                {link.label}
              </a>
            ))}
          </div>
        ))
      }
    </div>

    <div>
      <div class="flex gap-4">
        <p>instagram</p>
        <p>x</p>
      </div>

      <div>2026, Notch Magazine, LLC</div>
    </div>

    <div>Sign up to recieve news and updates</div>
  </div>
</footer>
